# ── DB Backend: "local" or "supabase" ─────────────────────────────────────────
DB_BACKEND=local

# ── Local PostgreSQL ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:@localhost:5432/VCrypto

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=sb_publishable_...
# Postgres password from Supabase Dashboard → Settings → Database → Database password
SUPABASE_DB_PASSWORD=your-supabase-db-password
# Optional: paste the full connection string here to override all of the above
SUPABASE_DB_URL=

# ── Binance API (optional — public endpoints work without keys) ────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Scheduler intervals (seconds) ─────────────────────────────────────────────
SCHEDULER_ENABLED=true
TICKER_INTERVAL_SECONDS=60
OHLCV_INTERVAL_SECONDS=300
MARKET_OVERVIEW_INTERVAL_SECONDS=900
COIN_DETAILS_INTERVAL_SECONDS=3600
FUNDING_RATE_INTERVAL_SECONDS=3600
FUTURES_INTERVAL_SECONDS=300

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/crypto_research.log